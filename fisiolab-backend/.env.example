# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL - Neon)
# Get from: neon.tech → project → Connection string
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Redis (Upstash REST)
# Get from: upstash.com → database → REST API section
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_rest_token

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Clerk JWT (get from Clerk Dashboard → API Keys → JWT Public Key)
CLERK_JWT_PUBLIC_KEY=your_clerk_jwt_public_key_here

# Cloudflare R2 (get from R2 Dashboard → Manage R2 API Tokens)
# Account ID: Cloudflare Dashboard → right sidebar
R2_ENDPOINT=https://69f4d50f46204be45534b15ca198e420.r2.cloudflarestorage.com
R2_ACCOUNT_ID=69f4d50f46204be45534b15ca198e420
R2_BUCKET_NAME=fisiolab-files
R2_ACCESS_KEY_ID=ddceb9de38674beeddb6612bd8d1b322
R2_SECRET_ACCESS_KEY=b3af145da47f493513fe16b8e8f78a651452972a359afb24b903323e6f96d82c
