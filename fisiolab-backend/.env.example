# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL - Neon)
# Get from: neon.tech → project → Connection string
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Redis (Upstash)
# Get from: upstash.com → database → Redis URL
REDIS_URL=rediss://default:pass@host.upstash.io:port

# Clerk JWT (get from Clerk Dashboard → API Keys → JWT Public Key)
CLERK_JWT_PUBLIC_KEY=your_clerk_jwt_public_key_here
