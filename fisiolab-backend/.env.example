# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL - Neon)
# Get from: neon.tech → project → Connection string
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Redis (Upstash REST)
# Get from: upstash.com → database → REST API section
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_rest_token

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Clerk JWT (get from Clerk Dashboard → API Keys → JWT Public Key)
CLERK_JWT_PUBLIC_KEY=your_clerk_jwt_public_key_here
